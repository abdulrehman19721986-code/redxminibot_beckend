{
  "name": "redxbot-ultra-backend",
  "version": "6.0.0",
  "description": "REDXBOT ULTRA — Advanced WhatsApp Bot by Abdul Rehman Rajpoot & Muzamil Khan",
  "main": "index.js",
  "scripts": {
    "start": "node --max-old-space-size=512 --optimize-for-size --expose-gc index.js",
    "dev": "nodemon index.js",
    "start:clean": "node cleanup.js && npm start",
    "start:heroku": "node --max-old-space-size=460 --optimize-for-size --expose-gc index.js"
  },
  "keywords": [
    "whatsapp-bot",
    "baileys",
    "redxbot",
    "ultra"
  ],
  "author": "Abdul Rehman Rajpoot",
  "contributors": [
    {
      "name": "Abdul Rehman Rajpoot",
      "role": "Lead Developer"
    },
    {
      "name": "Muzamil Khan",
      "role": "Co-Developer"
    }
  ],
  "license": "MIT",
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.15.8",
    "@hapi/boom": "^10.0.1",
    "@iamtraction/google-translate": "^2.0.1",
    "@vitalets/google-translate-api": "^9.2.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "adm-zip": "^0.5.16",
    "api-qasim": "^3.2.10",
    "awesome-phonenumber": "^5.9.0",
    "axios": "^1.8.4",
    "better-sqlite3": "^12.5.0",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "ffmpeg-static": "^5.2.0",
    "file-type": "^16.5.4",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.1",
    "fs-extra": "^11.2.0",
    "gifted-btns": "^1.0.2",
    "gtts": "^0.2.1",
    "jimp": "^1.6.0",
    "libphonenumber-js": "^1.11.18",
    "link-preview-js": "^3.0.5",
    "megajs": "^1.3.9",
    "moment-timezone": "^0.5.43",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.7.0",
    "node-id3": "^0.2.6",
    "node-webpmux": "^3.1.0",
    "pino": "^8.0.0",
    "pino-pretty": "^10.0.0",
    "qrcode": "^1.5.4",
    "ruhend-scraper": "^9.0.8",
    "sharp": "^0.32.6",
    "simple-git": "^3.30.0",
    "socket.io": "^4.8.1",
    "syntax-error": "^1.4.0",
    "wa-sticker-formatter": "^4.4.4",
    "yt-search": "^2.12.1",
    "ytdl-core": "^4.11.5"
  },
  "overrides": {
    "wa-sticker-formatter": {
      "sharp": "$sharp",
      "axios": "$axios",
      "fluent-ffmpeg": "$fluent-ffmpeg",
      "file-type": "$file-type",
      "fs-extra": "$fs-extra",
      "node-webpmux": "$node-webpmux"
    }
  },
  "config": {
    "cache": "/tmp/npmcache"
  }
}
